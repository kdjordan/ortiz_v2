# Copy to server/.env and fill in real values. NEVER commit server/.env.
# (.env is gitignored; real production values are provisioned in slice #11/HITL.)

# Admin password as a scrypt hash in "saltHex:derivedKeyHex" form.
# Generate one (replace the placeholder password):
#   node -e "const c=require('crypto');const s=c.randomBytes(16);console.log(s.toString('hex')+':'+c.scryptSync('your-password',s,64).toString('hex'))"
ADMIN_PASSWORD_HASH=

# Secret used to sign the session cookie. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Optional: port/host the admin API binds to locally (defaults 3001 / 127.0.0.1).
# PORT=3001
# HOST=127.0.0.1
